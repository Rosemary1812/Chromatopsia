{
  "name": "chromatopsia",
  "version": "0.1.0",
  "private": true,
  "description": "Chromatopsia - Multi-project parallel Agent development canvas",
  "scripts": {
    "build:agent": "pnpm --filter @chromatopsia/agent build",
    "build:cli": "pnpm --filter @chromatopsia/cli build",
    "build:canvas": "pnpm --filter @chromatopsia/canvas build",
    "dev:agent": "pnpm --filter @chromatopsia/agent dev",
    "dev:cli": "pnpm --filter @chromatopsia/cli dev",
    "dev:canvas": "pnpm --filter @chromatopsia/canvas dev",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  },
  "packageManager": "pnpm@9.15.0"
}
