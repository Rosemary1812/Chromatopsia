{
  "name": "chromatopsia",
  "version": "0.1.0",
  "private": true,
  "description": "Chromatopsia - Multi-project parallel Agent development canvas",
  "scripts": {
    "build:agent": "pnpm --filter @chromatopsia/agent build",
    "build:ui": "pnpm --filter @chromatopsia/ui-shell build",
    "dev:agent": "pnpm --filter @chromatopsia/agent dev",
    "dev:ui": "pnpm --filter @chromatopsia/ui-shell dev",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  },
  "packageManager": "pnpm@9.15.0"
}
