                                            \u001b[0m       \r\n     \u001b[38;5;24;48;5;195;2m 562 +\u001b[38;5;236m}                                                             \u001b[0m       \r\n     \u001b[38;5;236;2m 563\u001b[0m  \u001b[38;5;236;2m```\r\n\u001b[0m     \u001b[38;5;236;2m 564\r\n\u001b[0m     \u001b[38;5;236;2m 565\u001b[0m  \u001b[38;5;236;2m---\r\n\u001b[0m     \u001b[38;5;236;2m 566\r\n\u001b[0m     \u001b[38;5;160;48;5;224;2m 611 -\u001b[38;5;236m### 5.5 懒加载记忆预取                                        \u001b[0m       \r\n     \u001b[38;5;24;48;5;195;2m 567 +\u001b[38;5;236m### 4.5 懒加载记忆预取                                        \u001b[0m       \r\n     \u001b[38;5;236;2m 568\r\n\u001b[0m     \u001b[38;5;24;48;5;195;2m 569 +\u001b[38;5;236m**来源**: Claude Code                                         \u001b[0m       \r\n     \u001b[38;5;24;48;5;195;2m 570 +                                                              \u001b[0m       \r\n     \u001b[38;5;24;48;5;195;2m 571 +\u001b[38;5;236m**方案**:                                                     \u001b[0m       \r\n     \u001b[38;5;24;48;5;195;2m 572 +                                                              \u001b[0m       \r\n     \u001b[38;5;236;2m 573\u001b[0m  \u001b[38;5;236;2m```typescript\r\n\u001b[0m     \u001b[38;5;24;48;5;195;2m 574 +\u001b[38;5;236m// 在 query loop 入口启动                                     \u001b[0m       \r\n     \u001b[38;5;236;2m 575\u001b[0m  \u001b[38;5;236;2masync\u001b[0m \u001b[38;5;236;2mfunction*\u001b[0m \u001b[38;5;236;2mqueryLoop(params:\u001b[0m \u001b[38;5;236;2mQueryParams)\u001b[0m \u001b[38;5;236;2m{\r\n\u001b[0m     \u001b[38;5;160;48;5;224;2m 615 -  \u001b[38;5;236mconst pendingMemory = startMemoryPrefetch(state.messages, st\u001b[0m       \r\n     \u001b[38;5;160;48;5;224;2m     -\u001b[38;5;236mate.toolUseContext)                                           \u001b[0m       \r\n     \u001b[38;5;24;48;5;195;2m 576 +  \u001b[38;5;236m// 启动记忆预取（不阻