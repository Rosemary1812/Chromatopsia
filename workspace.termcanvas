 \u001b[38;5;236;2m 128\r\n\u001b[0m \u001b[38;5;236;2m 129\u001b[0m \u001b[38;5;246m/**\r\n\u001b[0m \u001b[38;5;236;2m 130\u001b[0m  \u001b[38;5;236m* Build the full LLM context \u001b[38;5;125mfor \u001b[38;5;236ma session.\r\n\u001b[0m \u001b[38;5;236;2m 131\u001b[0m  \u001b[38;5;236m*\r\n\u001b[0m \u001b[38;5;236;2m 132\u001b[0m  \u001b[38;5;236m* \u001b[38;5;246m@param \u001b[38;5;236msession       - The active session\r\n\u001b[0m \u001b[38;5;236;2m 133\u001b[0m  \u001b[38;5;236m* \u001b[38;5;246m@param \u001b[38;5;236mtask_type     - Inferred task \u001b[38;5;125mtype \u001b[38;5;236m(\u001b[38;5;125mfor \u001b[38;5;236mskill matching)\r\n\u001b[0m \u001b[38;5;236;2m 134\u001b[0m  \u001b[38;5;236m* \u001b[38;5;246m@param \u001b[38;5;236mmatched_skill - Precisely matched skill (\u001b[38;5;125mfrom \u001b[38;5;236mSkillRegistry.match)\r\n\u001b[0m \u001b[38;5;236;2m 135\u001b[0m  \u001b[38;5;236m* \u001b[38;5;246m@param \u001b[38;5;236mskill_reg     - Skill registry \u001b[38;5;125mfor \u001b[38;5;236mfuzzy lookups\r\n\u001b[0m \u001b[38;5;236;2m 136\u001b[0m  \u001b[38;5;236m* \u001b[38;5;246m@param \u001b[38;5;236moptions       - Optional configuration\r\n\u001b[0m \u001b[38;5;236;2m 137\u001b[0m  \u001b[38;5;236m* \u001b[38;5;246m@returns \u001b[38;5;236mLLMContext ready to be passed to the LLM provider\r\n\u001b[0m \u001b[38;5;236;2m 138\u001b[0m  \u001b[38;5;236m*/\r\n\u001b[0m \u001b[38;5;236;2m 139\u001b[0m \u001b[38;5;125mexport function \u001b[38;5;97mbuild_llm_context\u001b[38;5;236m(\r\n\u001b[0m \u001b[38;5;236;2m 140\u001b[0m   \u001b[38;5;236msession: Session,\r\n\u001b[0m \u001b[38;5;236;2m 141\u001b[0m   \u001b[38;5;236mtask_type: \u001b[38;5;31mstring\u001b[38;5;236m,\r\n\u001b[0m \u001b[38;5;236;2m 142\u001b[0m   \u001b[38;5;236mmatched_skill: Skill | \u001b[38;5;31mnull\u001b[38;5;236m,\r\n\u001b[0m \u001b[38;5;236;2m 143\u001b[0m   \u001b[38;5;236mskill_reg: SkillRegistry,\r\n\u001b[0m \u001b[38;5;236;2m 144\u001b[0m   \u001b[38;5;236mopti