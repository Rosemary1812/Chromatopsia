\u001b[2C1. \u001b[38;2;51;102;255;1mAgentLoopProvider\u001b[1C\u001b[0m(第22-130行)\u001b[1C是连接桥梁：\r\n\u001b[4C-\u001b[1C持有\u001b[1C\u001b[38;2;51;102;255mAgent\u001b[1C\u001b[0m实例\u001b[54C   \u001b[1C       \r\n\u001b[4C-\u001b[1C管理\u001b[1C\u001b[38;2;51;102;255mmessages\u001b[0m、\u001b[38;2;51;102;255mstreaming\u001b[1C\u001b[0m等状态\r\n    - 通过 \u001b[38;2;51;102;255magent.stream(userMessage) \u001b[0m消费 Agent 的异步消息流\r\n    - 使用 50ms debounce 批量更新 UI 状态\r\n  2. \u001b[1m消息流\u001b[0m：\r\n  user input → onSubmit() → agent.stream() → AsyncGenerator → enqueueMessage() →       \r\n  setMessages()\r\n  3. \u001b[1m状态共享\u001b[0m：\u001b[38;2;51;102;255mAgentLoopContext \u001b[0m提供：\r\n    - \u001b[38;2;51;102;255mstreaming\u001b[0m: 是否正在流式输出\r\n    - \u001b[38;2;51;102;255mmessages\u001b[0m: 消息历史\r\n    - \u001b[38;2;51;102;255monSubmit\u001b[0m: 提交用户输入\r\n    - \u001b[38;2;51;102;255mabort\u001b[0m: 中止当前运行\r\n\r\n  ---\r\n  \u001b[1m状态管理\r\n\r\n\u001b[0m  \u001b[1m多层独立状态\u001b[0m：\r\n\r\n  ┌────────────────┬───────────────────────────────┬────────────────────┐\r\n  │      状态      │             位置              │        用途        │\r\n  ├────────────────┼───────────────────────────────┼────────────────────┤\r\n  │ Agent 内部状态 │ \u001b[38;2;51;102;255mAgent._context.messages       \u001b[0m│ Agent 的推理上下文 │\r\n  ├────────────────┼───────────────────────────────┼────────────────────┤\r\n  │ UI 消息状态    │ \u001b[38;2;51;102;255muse-agent-loop.ts \u001b[0m的 \u001b[38;2;51;102;255museState \u001b[0m│ TUI 渲染           │\r\n  ├────────────────┼───────────────────────────────┼────────────────────┤\r\n  │ 流式状态       │ \u001b[38;2;51;102;255mstreamingRef\u001b[18C\u001b[0m│ 防重复提交         │\r\n  ├────────────────┼───────────────────────────────┼────────────────────┤\r\n  │ 待刷消息       │ \u001b[38;2;51;102;255mpendingMessagesRef\u001b[12C\u001b[0m│ debounce 批量更新  │\r\n  └────────────────┴───────────────────────────────┴────────────────────┘\r\n\r\n  \u001b[1mApproval\u001b[0m \u001b[1m流程\u001b[0m：\r\n  Agent._act()\r\n    → middleware.beforeToolUse()\r\n    → createApprovalMiddleware()\r\n    → globalApprovalManager.askUser()\r\n    → TUI useApprovalManager (React订阅)\r\n    → ApprovalPrompt 组件\r\n\r\n  \u001b[1m中间件机制\u001b[0m (\u001b[38;2;51;102;255magent-middleware.ts\u001b[0m)：\r\n  - \u001b[38;2;51;102;255mbeforeModel \u001b[0m/ \u001b[38;2;51;102;255mafterModel\r\n\u001b[0m  - \u001b[38;2;51;102;255mbeforeToolUse \u001b[0m/ \u001b[38;2;51;102;255mafterToolUse\r\n\u001b[0m  - \u001b[38;2;51;102;255mbeforeAgentStep \u001b[0m/ \u001b[38;2;51;102;255mafterAgentStep\r\n\u001b[0m  - 职责链模式，所有 middleware 按序执行\r\n\r\n  ---\r\n  \u001b[1m关键设计点\r\n\r\n\u001b[0m  1. \u001b[1m流式消费\u001b[0m：TUI 通过 \u001b[38;2;51;102;255mfor await...of \u001b[0m迭代 Agent 的 \u001b[38;2;51;102;255mstream() \u001b[0mGenerator，消息逐条 yield\r\n\u001b[38;2;215;119;87m ▐\u001b[48;2;0;0;0m▛███▜\u001b[49m▌   \u001b[39;1mClaude\u001b[0m \u001b[1mCode\u001b[0m \u001b[38;2;102;102;102mv2.1.89\r\n\u001b[38;2;215;119;87m▝▜\u001b[48;2;0;0;0m█████\u001b[49m▛▘  \u001b[38;2;102;102;102mMiniMax-M2.7 · API Usage Billing\r\n\u001b[38;2;215;119;87m  ▘▘ ▝▝    \u001b[38;2;102;102;102mD:\\coding\\agent\\agent调研\\helixent\r\n\r\n\u001b[0m  \u001b[38;2;102;102;102mRead \u001b[1m2\u001b[22m files (ctrl+o to expand)\r\n\r\n\u001b[38;2;0;0;0m● \u001b[39;1m架构总结\r\n\r\n\u001b[0m  \u001b[1mAgent\u001b[0m \u001b[1m层与\u001b[0m \u001b[1mTUI\u001b[0m \u001b[1m的连接\r\n\r\n\u001b[0m  \u001b[1m核心：\u001b[38;2;51;102;255muse-agent-loop.ts\r\n\r\n\u001b[0m  Agent (Agent.ts)  ←  React Context (AgentLoopContext)  →  TUI (App.tsx)\r\n\r\n  1. \u001b[38;2;51;102;255;1mAgentLoopProvider\u001b[0m (第22-130行) 是连接桥梁：\r\n    - 持有 \u001b[38;2;51;102;255mAgent \u001b[0m实例\r\n    - 管理 \u001b[38;2;51;102;255mmessages\u001b[0m、\u001b[38;2;51;102;255mstreaming \u001b[0m等状态\r\n    - 通过 \u001b[38;2;51;102;255magent.stream(userMessage) \u001b[0m消费 Agent 的异步消息流\r\n    - 使用 50ms debounce 批量更新 UI 状态\r\n  2. \u001b[1m消息流\u001b[0m：\r\n  user inpu