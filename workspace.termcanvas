                "scrollback": " 383 +      \u001b[38;5;125mlet \u001b[38;5;236mtimedOut = \u001b[38;5;31mfalse\u001b[38;5;236m;\u001b[37C\u001b[0m       \r\n     \u001b[38;5;24;48;5;195m 384 +\u001b[64X\u001b[64C\u001b[0m       \r\n     \u001b[38;5;24;48;5;195m 385 +      \u001b[38;5;125mwhile \u001b[38;5;236m(\u001b[38;5;31mtrue\u001b[38;5;236m) {\u001b[44X\u001b[44C\u001b[0m       \r\n     \u001b[38;5;24;48;5;195m 386 +        \u001b[38;5;125mconst \u001b[38;5;236mtimeoutPromise = \u001b[38;5;125mnew \u001b[38;5;31mPromise\u001b[38;5;236m<\u001b[38;5;31mnever\u001b[38;5;236m>((\u001b[38;5;31m_, reject\u001b[38;5;236m) =>\u001b[0m       \r\n     \u001b[38;5;24;48;5;195m 387 +\u001b[10X\u001b[10C\u001b[38;5;31msetTimeout\u001b[38;5;236m(() => reject(\u001b[38;5;125mnew \u001b[38;5;31mError\u001b[38;5;236m(\u001b[38;5;24m'Stream timeout (60s\u001b[0m       \r\n     \u001b[38;5;24;48;5;195m     +)'\u001b[38;5;236m)), STREAM_TIMEOUT_MS)\u001b[40X\u001b[40C\u001b[0m       \r\n     \u001b[38;5;24;48;5;195m 388 +        \u001b[38;5;236m);\u001b[54X\u001b[54C\u001b[0m       \r\n     \u001b[38;5;24;48;5;195m 389 +        \u001b[38;5;125mconst \u001b[38;5;236mnextPromise = gen.next();\u001b[25X\u001b[25C\u001b[0m       \r\n     \u001b[38;5;24;48;5;195m 390 +\u001b[64X\u001b[64C\u001b[0m       \r\n     \u001b[38;5;24;48;5;195m 391 +        \u001b[38;5;246m// Race: stream chunk vs timeout\u001b[24X\u001b[24C\u001b[0m       \r\n     \u001b[38;5;24;48;5;195m 392 +        \u001b[38;5;236mresult = \u001b[38;5;125mawait \u001b[38;5;31mPromise\u001b[38;5;236m.race([nextPromise, timeoutPromise\u001b[0m       \r\n     \u001b[38;5;24;48;5;195m     +\u001b[38;5;236m]);\u001b[61X\u001b[61C\u001b[0m       \r\n     \u001b[38;5;24;48;5;195m 393 +        \u001b[38;5;125mif \u001b[38;5;236m(result.done || timedOut) \u001b[38;5;125mbreak\u001b[38;5;236m;\u001b[21X\u001b[21C\u001b[0m       \r\n     \u001b[38;5;24;48;5;195m 394 +\u001b[64X\u001b[64C\u001b[0m       \r\n     \u001b[38;5;236;2m 395