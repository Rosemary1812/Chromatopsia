001b[1m17\u001b[0m lines\r\n     \u001b[38;5;236;2m 1168\u001b[10C\u001b[38;5;31;22mconsole\u001b[38;5;236m.log(m.content.slice(\u001b[38;5;31m0\u001b[38;5;236m, \u001b[38;5;31m400\u001b[38;5;236m) + (m.content.length > \u001b[38;5;31m400 \u001b[38;5;236m? \u001b[38;5;24m'\\n...(截        \r\n\u001b[0m     \u001b[38;5;236;2m \u001b[0m      \u001b[38;5;24m断)...' \u001b[38;5;236m: \u001b[38;5;24m''\u001b[38;5;236m));\r\n\u001b[0m     \u001b[38;5;236;2m 1169\u001b[0m        \u001b[38;5;236m}\r\n\u001b[0m     \u001b[38;5;236;2m 1170\r\n\u001b[0m     \u001b[38;5;160;48;5;224m 1171 -      \u001b[38;5;236m// MiniMax API 不接受 system role，将内容合并到首条 user 消息\u001b[15X\u001b[15C\u001b[0m       \r\n     \u001b[38;5;160;48;5;224m 1172 -      \u001b[38;5;236mconst systemMsgs = ctx.messages.filter(m => m.role === 'system');\u001b[11X\u001b[11C\u001b[0m       \r\n     \u001b[38;5;160;48;5;224m 1173 -      \u001b[38;5;236mconst nonSystemMsgs = ctx.messages.filter(m => m.role !== 'system');        \u001b[0m       \r\n     \u001b[38;5;160;48;5;224m 1174 -      \u001b[38;5;236mlet llmMessages: { role: 'user' | 'assistant'; content: string }[] = [];    \u001b[0m       \r\n     \u001b[38;5;24;48;5;195m 1171 +      \u001b[38;5;246m// T3: 直接用原始对话 + system prompt 发给 LLM\u001b[30X\u001b[30C\u001b[0m       \r\n     \u001b[38;5;24;48;5;195m 1172 +      \u001b[38;5;246m// build_llm_context 把所有内容放 system 消息里，这里直接用原始对话测试完整 \u001b[0m       \r\n     \u001b[38;5;24;48;5;195m      +\u001b[38;5;246mpipeline\u001b[74X\u001b[74C\u001b[0m       \r\n     \u001b[38;5;24;48;5;195m 1173 +      \u001b[38;5;125mconst \u001b[38;5;236msystemPrompt = build_system_prompt(session);\u001b[26X\u001b[26C\u001b[0m       \r\n     \u001b[38;5;24;48;5;195m 1174 +      \u001b[38;5;125mconst \u001b[38;5;236mllmMessages = [\u001b[55X\u001b[55C\u001b[0m       \r\n     \u001b[38;5;24;48;5;195m 1175 +        \u001b[38;5;236m{ \u001b[38;5;31mrole\u001b[38;5;236m: \u001b[38;5;24m'system' \u001b[38;5;125mas const\u001b[38;5;236m, \u00