                                         │   \r\n  ├─────────────┼─────────────────────────────────────────────────────────────┤   \r\n  │ \u001b[1m工具系统\u001b[0m    │ 7 个内置工具 + ToolRegistry 插件化架构，Zod                 │   \r\n  │             │ 参数校验，沙盒隔离                                          │   \r\n  ├─────────────┼─────────────────────────────────────────────────────────────┤   \r\n  │ \u001b[1m会话管理\u001b[0m    │ JSONL 持久化，自动上下文压缩 (LLM summarization)，轮次上限  │   \r\n  │             │ 16 轮                                                       │   \r\n  ├─────────────┼─────────────────────────────────────────────────────────────┤   \r\n  │ \u001b[1m记忆系统\u001b[0m    │ 跨会话持久记忆，LLM 决策写入 + 关键词检索注入               │   \r\n  ├─────────────┼─────────────────────────────────────────────────────────────┤   \r\n  │ \u001b[1m自学习层\u001b[0m    │ SkillRegistry 经验固化管道，LLM 合成 + 人工审批闭环         │   \r\n  ├─────────────┼─────────────────────────────────────────────────────────────┤   \r\n  │ \u001b[1m安全机制\u001b[0m    │ ApprovalHook 模式匹配自动拦截危险操作（\u001b[38;2;51;102;255mrm -rf\u001b[0m、\u001b[38;2;51;102;255mcurl | sh    \u001b[0m│   \r\n  │             │ 等）                                                        │   \r\n  └─────────────┴─────────────────────────────────────────────────────────────┘   \r\n\r\n  \u001b[1mAI\u001b[0m \u001b[1m提升效率的核心机制\r\n\r\n\u001b[0m  1. \u001b[1m流式\u001b[0m \u001b[1mTool\u001b[0m \u001b[1mCall\u001b[0m \u001b[1m边推理边执行\u001b[0m — Claude streaming 期间即可触发\r\n  \u001b[38;2;51;102;255mon_tool_call_start\u001b[0m，无需等完整响应\r\n  2. \u001b[1m危险操作分级审批\u001b[0m — safe/warning/dangerous 三级，warning/dangerous\r\n  工具串行执行 + 人工 gate\r\n  3. \u001b[1m上下文自动压缩\u001b[0m — 超阈值后 LLM summarization + truncate 回退，不再硬性截断    \r\n  4. \u001b[1m经验固化管道\u001b[0m — 每 N 轮调用 LLM 合成\r\n  Skill，沉淀为可复用工作流（用户审批后才激活）\r\n  5. \u001b[1m记忆按需注入\u001b[0m — LLM decider 决定是否写记忆，关键词匹配决定读哪些记忆注入上下文\r\n\r\n  \u001b[1m简历描述建议\r\n\r\n\u001b[0m  \u001b[2m▎\u001b[0m \u001b[1;3;2mChromatopsia\u001b[0m \u001b[1;3;2