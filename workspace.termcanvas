;236mit(\u001b[38;5;24m'load_session skips corrupted lines'\u001b[38;5;236m, \u001b[38;5;125masync \u001b[38;5;236m() => {\r\n\u001b[0m     \u001b[38;5;236;2m 119\u001b[0m        \u001b[38;5;246m// Manually write corrupted JSONL\r\n\u001b[0m     \u001b[38;5;160;48;5;224m 120 -      \u001b[38;5;236mconst { writeFile } = await import('fs/promises');\u001b[26X\u001b[26C\u001b[0m       \r\n     \u001b[38;5;24;48;5;195m 120 +      \u001b[38;5;125mconst \u001b[38;5;236m{ writeFile\u001b[48;5;153m,\u001b[48;5;195m \u001b[48;5;153mmkdir \u001b[48;5;195m} = \u001b[38;5;125mawait import\u001b[38;5;236m(\u001b[38;5;24m'fs/promises'\u001b[38;5;236m);\u001b[19X\u001b[19C\u001b[0m       \r\n     \u001b[38;5;24;48;5;195m 121 +      \u001b[38;5;125mawait \u001b[38;5;236mmkdir(TEST_DIR, { \u001b[38;5;31mrecursive\u001b[38;5;236m: \u001b[38;5;31mtrue \u001b[38;5;236m});\u001b[33X\u001b[33C\u001b[0m       \r\n     \u001b[38;5;236;2m 122\u001b[0m        \u001b[38;5;125mconst \u001b[38;5;236mcorruptedPath = resolve(TEST_DIR, \u001b[38;5;24m'corrupt.jsonl'\u001b[38;5;236m);\r\n\u001b[0m     \u001b[38;5;236;2m 123\u001b[0m        \u001b[38;5;125mawait \u001b[38;5;236mwriteFile(corruptedPath, \u001b[38;5;24m'{\"role\":\"user\",\"content\":\"good\"}\\nnot valid        \r\n\u001b[0m     \u001b[38;5;236;2m \u001b[0m     \u001b[38;5;24mjson\\n{\"role\":\"assistant\",\"content\":\"ok\"}\\n'\u001b[38;5;236m, \u001b[38;5;24m'utf-8'\u001b[38;5;236m);\r\n\u001b[0m     \u001b[38;5;236;2m 124\r\n\u001b[0m     \u001b[38;5;236;2m 125\u001b[0m        \u001b[38;5;246m// Manually create an index entry for this session\r\n\u001b[0m     \u001b[38;5;160;48;5;224m 125 -      \u001b[38;5;236mconst { readFile } = await import('fs/promises');\u001b[27X\u001b[27C\u001b[0m       \r\n     \u001b[38;5;236;2m 126\u001b[0m        \u001b[38;5;125mconst \u001b[38;5;236mindex_path = resolve(TEST_DIR, \u001b[38;5;24m'index.json'\u001b[38;5;236m);\r\n\u001b[0m     \u001b[38;5;236;2m 127\u001b[0m        \u001b[38;5;125mawai