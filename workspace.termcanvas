6;2m 46\r\n\r\n\u001b[38;2;0;102;153;22m● \u001b[39;1mUpdate\u001b[0m(.claude\\skills\\agent-build-sop\\references\\workflow.md)\r\n\u001b[38;2;102;102;102m  ⎿  \u001b[0mAdded \u001b[1m3\u001b[0m lines, removed \u001b[1m1\u001b[0m line\r\n     \u001b[38;5;236;2m 49\u001b[0m  \u001b[38;5;236m```bash\r\n\u001b[0m     \u001b[38;5;236;2m 50\u001b[0m  \u001b[38;5;236mgit checkout main\r\n\u001b[0m     \u001b[38;5;236;2m 51\u001b[0m  \u001b[38;5;236mgit pull origin main\r\n\u001b[0m     \u001b[38;5;160;48;5;224m 52 -\u001b[38;5;236mgit checkout -b t{xx}-{name}\u001b[55X\u001b[55C\u001b[0m       \r\n     \u001b[38;5;24;48;5;195m 52 +\u001b[38;5;236mgit checkout -b \u001b[48;5;153mphase\u001b[48;5;195m{\u001b[48;5;153mX\u001b[48;5;195m}\u001b[59X\u001b[59C\u001b[0m       \r\n     \u001b[38;5;236;2m 53\u001b[0m  \u001b[38;5;236m```\r\n\u001b[0m     \u001b[38;5;236;2m 54\r\n\u001b[0m     \u001b[38;5;24;48;5;195m 55 +\u001b[38;5;236m例如 Phase 1：`git checkout -b phase1`\u001b[45X\u001b[45C\u001b[0m       \r\n     \u001b[38;5;24;48;5;195m 56 +\u001b[83X\u001b[83C\u001b[0m       \r\n     \u001b[38;5;236;2m 57\u001b[0m  \u001b[38;5;236m---\r\n\u001b[0m     \u001b[38;5;236;2m 58\r\n\u001b[0m     \u001b[38;5;236;2m 59\u001b[0m  \u001b[38;5;236m## 每个任务的标准流程（Step 1~5）\r\n\r\n\u001b[38;2;0;102;153m● \u001b[39;1mUpdate\u001b[0m(.claude\\skills\\agent-build-sop\\references\\workflow.md)\r\n\u001b[38;2;102;102;102m  ⎿  \u001b[0mAdded \u001b[1m3\u001b[0m lines, removed \u001b[1m3\u001b[0m lines\r\n     \u001b[38;5;236;2m 111\r\n\u001b[0m     \u001b[38;5;236;2m 112\u001b[0m  \u001b[38;5;236m## Commit 格式\r\n\u001b[0m     \u001b[38;5;236;2m 113\r\n\u001b[0m     \u001b[38;5;160;48;5;224m 114 -\u001b[38;5;236m收到用户「✅ T-XX 验证通过」后，执行：\u001b[44X\u001b[44C\u001b[0m       \r\n     \u001b[38;5;24;48;5;195m 114 +\u001b[38;5;236m收到用户「✅ \u001b[48;5;153mPhase\u001b[48;5;195m \u001b[48;5;153mX \u001b[48;5;195m验证通过」后，执行：\u001b[41X\u001b[41C\u001b[0m       \r\n     \u001b[38;5;236;2m 115\r\n\u001b[0m     \u00