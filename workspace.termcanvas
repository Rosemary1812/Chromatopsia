55;1mCreate file-------\u001b[35C--------------\u001b[21C\u001b[38;2;102;102;102;22m   \u001b[38;2;153;153;153m \u001b[0m            \u001b[38;2;102;102;102mpackages\\agent\\src\\session\\s\u001b[1Cmmarizer.ts----------\u001b[24C\u001b[0m           \u001b[38;2;175;175;175m╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌\u001b[0m \u001b[38;5;236;2m   1 \u001b[38;5;246;22m// ============================================================\u001b[9C\u001b[0m           \u001b[38;5;246m--------------n Summariz\u001b[0m           \u001b[38;5;246m缩长对话上下文----------\r\n\u001b[0m \u001b[38;5;236;2m   3 \u001b[38;5;246;22m// T-16     -------\u001b[54C-------\u001b[7C\u001b[0m \u001b[1C         \r\n\u001b[1C\u001b[38;5;236;2m \u001b[2C4\u001b[1C\u001b[38;5;246;22m//\u001b[1C============================================================\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m  \u001b[38;5;236;2m5\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m  \u001b[38;5;236;2m6\u001b[0m \u001b[38;5;125mimport type \u001b[38;5;236m{ Message, LLMProvider, CompressionConfig, CompressionMetadata } \u001b[38;5;125mfrom \u001b[38;5;24m'../types.js'\u001b[38;5;236m;   \r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m  \u001b[38;5;236;2m7\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m  \u001b[38;5;236;2m8\u001b[0m \u001b[38;5;246m// 默认配置\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m  \u001b[38;5;236;2m9\u001b[0m \u001b[38;5;125mexport const \u001b[38;5;236mDEFAULT_COMPRESSION_CONFIG: Required<CompressionConfig> = {\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m10\u001b[0m   \u001b[38;5;236mcompress_threshold: \u001b[38;5;31m4500\u001b[38;5;236m,\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m11\u001b[0m   \u001b[38;5;236mpreserve_recent: \u001b[38;5;31m4\u001b[38;5;236m,\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m12\u001b[0m   \u001b[38;5;236mmin_summarizable: \u001b[38;5;31m6\u001b[38;5;236m,\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m13\u001b[0m \u001b[38;5;236m};\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m14\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m15\u001b[0m \u001b[38;5;246m/**\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m16\u001b[0m  \u001b[38;5;236m* 将消息列表格式化为摘要 prompt 的输入\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m17\u001b[0m  \u001b[38;5;236m*/\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m18\u001b[0m \u001b[38;5;125mfunction \u001b[38;5;97mformat_messages_for_summary\u001b[38;5;236m(\u001b[38;5;31mmessages: Message[]\u001b[38;5;236m): \u001b[38;5;97mstring \u001b[38;5;236m{\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m19\u001b[0m   \u001b[38;5;125mreturn \u001b[38;5;236mmessages\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m20\u001b[0m     \u001b[38;5;236m.map((\u001b[38;5;31mmsg, i\u001b[38;5;236m) => {\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m21\u001b[0m       \u001b[38;5;125mconst \u001b[38;5;236mrole = msg.role.padEnd(\u001b[38;5;31m10\u001b[38;5;236m, \u001b[38;5;24m' '\u001b[38;5;236m);\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m22\u001b[0m       \u001b[38;5;125mconst \u001b[38;5;236mcontent = msg.content.length > \u001b[38;5;31m300 \u001b[38;5;236m? msg.content.slice(\u001b[38;5;31m0\u001b[38;5;236m, \u001b[38;5;31m300\u001b[38;5;236m) + \u001b[38;5;24m'...' \u001b[38;5;236m: msg.content   \r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m    \u001b[38;5;236m;\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m23\u001b[0m       \u001b[38;5;125mreturn \u001b[38;5;24m`[\u001b[38;5;236m${i + \u001b[38;5;31m1\u001b[38;5;236m}\u001b[38;5;24m] \u001b[38;5;236m${role} \u001b[38;5;24m| \u001b[38;5;236m${content}\u001b[38;5;24m`\u001b[38;5;236m;\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m24\u001b[0m     \u001b[38;5;236m})\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m25\u001b[0m     \u001b[38;5;236m.join(\u001b[38;5;24m'\\n'\u001b[38;5;236m);\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m26\u001b[0m \u001b[38;5;236m}\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m27\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m28\u001b[0m \u001b[38;5;246m/**\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m29\u001b[0m  \u001b[38;5;236m* 构建摘要生成 prompt\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m30\u001b[0m  \u001b[38;5;236m*/\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m31\u001b[0m \u001b[38;5;125mexport function \u001b[38;5;97mbuild_summarize_prompt\u001b[38;5;236m(\u001b[38;5;31mmessages_to_compress: Message[]\u001b[38;5;236m): \u001b[38;5;97mstring \u001b[38;5;236m{\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m32\u001b[0m   \u001b[38;5;125mreturn \u001b[38;5;24m`请将以下对话历史压缩为一段简洁的摘要。\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m33\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m34\u001b[0m \u001b[38;5;236m要求：\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m35\u001b[0m \u001b[38;5;31m1. \u001b[38;5;236m保留关键决策、已完成的工作、当前任务状态\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m36\u001b[0m \u001b[38;5;31m2. \u001b[38;5;236m忽略无关的试错过程\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m37\u001b[0m \u001b[38;5;31m3. \u001b[38;5;236m用中文输出，\u001b[38;5;31m200 \u001b[38;5;236m字以内\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m38\u001b[0m \u001b[38;5;31m4. \u001b[38;5;236m摘要需要让后续 Agent 能接续当前工作\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m39\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m40\u001b[0m \u001b[38;5;236m对话历史：\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m41\u001b[0m \u001b[38;5;236m${format_messages_for_summary(messages_to_compress)}\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m42\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m43\u001b[0m \u001b[38;5;236m摘要：\u001b[38;5;24m`;\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m44\u001b[0m \u001b[38;5;236m}\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m45\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m46\u001b[0m \u001b[38;5;246m/**\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m47\u001b[0m  \u001b[38;5;236m* 检查是否需要压缩（按消息数量估算）\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m48\u001b[0m  \u001b[38;5;236m*/\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m49\u001b[0m \u001b[38;5;125mexport function \u001b[38;5;97mneeds_compression\u001b[38;5;236m(\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m50\u001b[0m   \u001b[38;5;236mmessages: Message[],\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m51\u001b[0m   \u001b[38;5;236mconfig: CompressionConfig,\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m52\u001b[0m \u001b[38;5;236m): \u001b[38;5;31mboolean \u001b[38;5;236m{\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m53\u001b[0m   \u001b[38;5;246m// 简单按消息数量粗估：平均每条消息约 200 tokens\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m54\u001b[0m   \u001b[38;5;246m// 保守估算，实际按具体 token 数会更准确\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m55\u001b[0m   \u001b[38;5;125mconst \u001b[38;5;236mestimated_tokens = messages.length * \u001b[38;5;31m200\u001b[38;5;236m;\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m56\u001b[0m   \u001b[38;5;125mreturn \u001b[38;5;236mestimated_tokens >= config.compress_threshold;\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m57\u001b[0m \u001b[38;5;236m}\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m58\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m59\u001b[0m \u001b[38;5;246m/**\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m60\u001b[0m  \u001b[38;5;236m* 核心压缩函数\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m61\u001b[0m  \u001b[38;5;236m*\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m62\u001b[0m  \u001b[38;5;236m* \u001b[38;5;246m@param \u001b[38;5;236mmessages 当前消息列表\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m63\u001b[0m  \u001b[38;5;236m* \u001b[38;5;246m@param \u001b[38;5;236mconfig 压缩配置\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m64\u001b[0m  \u001b[38;5;236m* \u001b[38;5;246m@param \u001b[38;5;236mprovider LLM Provider（用于生成摘要）\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m65\u001b[0m  \u001b[38;5;236m* \u001b[38;5;246m@returns \u001b[38;5;236m压缩后的消息列表 + 元数据\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m66\u001b[0m  \u001b[38;5;236m*/\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m67\u001b[0m \u001b[38;5;125mexport async function \u001b[38;5;97mcompress_session\u001b[38;5;236m(\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m68\u001b[0m   \u001b[38;5;236mmessages: Message[],\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m69\u001b[0m   \u001b[38;5;236mconfig: CompressionConfig,\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m70\u001b[0m   \u001b[38;5;236mprovider: LLMProvider,\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m71\u001b[0m \u001b[38;5;236m): \u001b[38;5;31mPromise\u001b[38;5;236m<{ \u001b[38;5;31mcompressed\u001b[38;5;236m: Message[]; metadata: CompressionMetadata }> {\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m72\u001b[0m   \u001b[38;5;125mconst \u001b[38;5;236mresolved_config: Required<CompressionConfig> = {\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m73\u001b[0m     \u001b[38;5;236mcompress_threshold: config.compress_threshold ?? DEFAULT_COMPRESSION_CONFIG.compress_thresho   \r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m    \u001b[38;5;236mld,\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m74\u001b[0m     \u001b[38;5;236mpreserve_recent: config.preserve_recent ?? DEFAULT_COMPRESSION_CONFI