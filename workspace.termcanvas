 \u001b[38;5;236mto\u001b[0m \u001b[38;5;236mthe\u001b[0m \u001b[38;5;236mLLM:\u001b[0m                                                      \u001b[38;5;236;2m \u001b[0m  \u001b[38;5;236;2m5\u001b[0m \u001b[38;5;236m *\u001b[0m \u001b[38;5;31m1. \u001b[38;5;236mSystem\u001b[0m \u001b[38;5;236mprompt\u001b[0m \u001b[38;5;236m(\u001b[38;5;125mwith \u001b[38;5;236mproject\u001b[0m \u001b[38;5;236mcontext,\u001b[0m \u001b[38;5;236muser\u001b[0m \u001b[38;5;236mcontext)\u001b[0m                                            \u001b[38;5;236;2m \u001b[0m  \u001b[38;5;236;2m6\u001b[0m \u001b[38;5;236m *\u001b[0m \u001b[38;5;31m2. \u001b[38;5;236mSkill\u001b[0m \u001b[38;5;236minjection\u001b[0m \u001b[38;5;236m(matched\u001b[0m \u001b[38;5;236mskill\u001b[0m \u001b[38;5;236mor\u001b[0m \u001b[38;5;236mfuzzy-matched\u001b[0m \u001b[38;5;236mrelated\u001b[0m \u001b[38;5;236mskills)\u001b[0m                               \u001b[38;5;236;2m \u001b[0m  \u001b[38;5;236;2m7\u001b[0m \u001b[38;5;236m *\u001b[0m \u001b[38;5;31m3. \u001b[38;5;236mRecent\u001b[0m \u001b[38;5;236mconversation\u001b[0m \u001b[38;5;236mhistory\u001b[0m                                                                   \u001b[38;5;236;2m \u001b[0m  \u001b[38;5;236;2m8\u001b[0m \u001b[38;5;236m */\u001b[0m                                                                                                 \u001b[38;5;236;2m \u001b[0m  \u001b[38;5;236;2m9\u001b[0m                                                                                                     \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m10\u001b[0m \u001b[38;5;125mimport type \u001b[38;5;236m{\u001b[0m \u001b[38;5;236mMessage,\u001b[0m \u001b[38;5;236mSession,\u001b[0m \u001b[38;5;236mSkill,\u001b[0m \u001b[38;5;236mLLMContext,\u001b[0m \u001b[38;5;236mProjectContext,\u001b[0m \u001b[38;5;236mUserContext\u001b[0m \u001b[38;5;236m}\u001b[0m \u001b[38;5;125mfrom \u001b[38;5;24m'../types.\u001b[0m    \u001b[38;5;236;2m \u001b[0m    \u001b[38;5;24mjs'\u001b[38;5;236m;\u001b[0m                                                                                               \r\n\u001b[1C\u001b[38;5;236;2m \u001b[1C11\u001b[1C\u001b[38;5;125;22mimport type \u001b[38;5;236m{\u001b[1CSkillRegistry\u001b[1C}\u001b[1C\u001b[38;5;125mfrom \u001b[38;5;24m'../skills/registry.js'\u001b[38;5;236m;\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m12\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m13\u001b[0m \u001b[38;5;246m// ----------------------------------------------------------------\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m14\u001b[0m \u001b[38;5;246m// System prompt building\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m15\u001b[0m \u001b[38;5;246m// ----------------------------------------------------------------\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m16\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m17\u001b[0m \u001b[38;5;246m/**\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m18\u001b[0m  \u001b[38;5;236m* Build the system prompt \u001b[38;5;125mfor \u001b[38;5;236ma session.\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m19\u001b[0m  \u001b[38;5;236m* Includes project context, user context, and agent role definition.\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m20\u001b[0m  \u001b[38;5;236m*/\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m21\u001b[0m \u001b[38;5;125mexport function \u001b[38;5;97mbuild_system_prompt\u001b[38;5;236m(\u001b[38;5;31msession: Session\u001b[38;5;236m): \u001b[38;5;97mstring \u001b[38;5;236m{\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m22\u001b[0m   \u001b[38;5;125mconst \u001b[38;5;236mparts: \u001b[38;5;31mstring\u001b[38;5;236m[] = [\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m23\u001b[0m     \u001b[38;5;24m'你是 Chromatopsia，一个面向开发者的 AI 编程助手。'\u001b[38;5;236m,\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m24\u001b[0m     \u001b[38;5;24m'你可以使用工具来读取、编辑、搜索文件和执行命令。'\u001b[38;5;236m,\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m25\u001b[0m     \u001b[38;5;24m'始终优先使用工具完成任务，而非仅仅描述如何做。'\u001b[38;5;236m,\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m26\u001b[0m   \u001b[38;5;236m];\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m27\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m28\u001b[0m   \u001b[38;5;125mif \u001b[38;5;236m(session.project_context) {\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m29\u001b[0m     \u001b[38;5;125mconst \u001b[38;5;236mctx = session.project_context;\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m30\u001b[0m     \u001b[38;5;236mparts.push(\u001b[38;5;24m''\u001b[38;5;236m);\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m31\u001b[0m     \u001b[38;5;236mparts.push(\u001b[38;5;24m`【项目】\u001b[38;5;236m${ctx.name}\u001b[38;5;24m`\u001b[38;5;236m);\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m32\u001b[0m     \u001b[38;5;236mparts.push(\u001b[38;5;24m`根目录：\u001b[38;5;236m${ctx.root}\u001b[38;5;24m`\u001b[38;5;236m);\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m33\u001b[0m     \u001b[38;5;125mif \u001b[38;5;236m(ctx.language) parts.push(\u001b[38;5;24m`语言：\u001b[38;5;236m${ctx.language}\u001b[38;5;24m`\u001b[38;5;236m);\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m34\u001b[0m     \u001b[38;5;125mif \u001b[38;5;236m(ctx.framework) parts.push(\u001b[38;5;24m`框架：\u001b[38;5;236m${ctx.framework}\u001b[38;5;24m`\u001b[38;5;236m);\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m35\u001b[0m     \u001b[38;5;125mif \u001b[38;5;236m(ctx.description) parts.push(\u001b[38;5;24m`描述：\u001b[38;5;236m${ctx.description}\u001b[38;5;24m`\u001b[38;5;236m);\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m36\u001b[0m   \u001b[38;5;236m}\r\n\u001b[0m \u001b[38;5;236;2m \u001b[0m \u001b[38;5;236;2m37\r\n\u