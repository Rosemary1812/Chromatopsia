;5;153m Phase 1 |\u001b[39;48;5;195m\u001b[28X\u001b[28C\u001b[0m       \r\n     \u001b[38;5;24;48;5;195m 23 +\u001b[38;5;236m| T-06 | `packages/agent/src/tools/registry.ts` |\u001b[48;5;153m Phase 2 |\u001b[39;48;5;195m\u001b[24X\u001b[24C\u001b[0m       \r\n     \u001b[38;5;24;48;5;195m 24 +\u001b[38;5;236m| T-07 | `packages/agent/src/tools/executor.ts` |\u001b[48;5;153m Phase 2 |\u001b[39;48;5;195m\u001b[24X\u001b[24C\u001b[0m\r\n     \u001b[38;5;24;48;5;195m 25 +\u001b[38;5;236m| T-08 | `packages/agent/src/tools/bash.ts` |\u001b[48;5;153m Phase 2 |\u001b[39;48;5;195m\u001b[28X\u001b[28C\u001b[0m       \r\n     \u001b[38;5;24;48;5;195m 26 +\u001b[38;5;236m| T-09 | `packages/agent/src/tools/read.ts` |\u001b[48;5;153m Phase 2 |\u001b[39;48;5;195m\u001b[28X\u001b[28C\u001b[0m       \r\n     \u001b[38;5;24;48;5;195m 27 +\u001b[38;5;236m| T-10 | `packages/agent/src/tools/edit.ts` |\u001b[48;5;153m Phase 2 |\u001b[39;48;5;195m\u001b[28X\u001b[28C\u001b[0m       \r\n     \u001b[38;5;24;48;5;195m 28 +\u001b[38;5;236m| T-11 | `packages/agent/src/tools/grep.ts` + `glob.ts` |\u001b[48;5;153m Phase 2 |\u001b[39;48;5;195m\u001b[16X\u001b[16C\u001b[0m       \r\n     \u001b[38;5;24;48;5;195m 29 +\u001b[38;5;236m| T-12 | `packages/agent/src/tools/websearch.ts` |\u001b[48;5;153m Phase 2 |\u001b[39;48;5;195m\u001b[23X\u001b[23C\u001b[0m       \r\n     \u001b[38;5;24;48;5;195m 30 +\u001b[38;5;236m| T-13 | `packages/agent/src/tools/webfetch.ts` |\u001b[48;5;153m Phase 2 |\u001b[39;48;5;195m\u001b[24X\u001b[24C\u001b[0m       \r\n     \u001b[38;5;24;48;5;195m 31 +\u001b[38;5;236m| T-14 | `packages/agent/src/session/history.ts` |\u001b[48;5;153m Phase 3 |\u001b[39;48;5;195m\u001b[23X\u001b[23C\u001b[0m       \r\n     \u001b[38;5;24;48;5;195m 32 +\u001b[38;5;236m| T-15 | `packages/agent/src/session/context.ts` |\u001b[48;5;153m Phase 3 |\u001b[39;48;5;195m\u001b[23X\u001b[23C\u001b[0m       \r\n     \u001b[38;5;24;48;5;195m 33 +\u001b[38;5;236m| T-16 | `packages/agent/src/session/summa