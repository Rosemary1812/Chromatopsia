{
  "name": "@chromatopsia/terminal",
  "version": "0.1.0",
  "description": "Chromatopsia Terminal REPL - Ink-based TUI for the coding agent",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/app.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@chromatopsia/agent": "workspace:*",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2",
    "tsx": "^4.19.2",
    "ink": "^5.1.0"
  },
  "peerDependencies": {
    "ink": "^5.1.0",
    "react": "^18.3.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
