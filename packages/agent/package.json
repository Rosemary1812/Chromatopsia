{
  "name": "@chromatopsia/agent",
  "version": "0.1.0",
  "description": "Chromatopsia Agent - Interactive terminal coding agent powered by LLM",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsx src/repl/app.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "openai": "^4.77.0",
    "zod": "^3.23.8",
    "yaml": "^2.6.1",
    "turndown": "^7.2.0",
    "highlight.js": "^11.10.0",
    "flock": "^0.1.0",
    "exponential-backoff": "^3.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/turndown": "^5.0.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "tsx": "^4.19.2",
    "ink": "^5.1.0",
    "react": "^18.3.1"
  },
  "peerDependencies": {
    "ink": "^5.1.0",
    "react": "^18.3.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
